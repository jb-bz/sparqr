#!/usr/bin/env bash
# bin/sparc-init — Initialize a new SPARC pipeline in the current directory.
#
# - Creates ./sparc.config.yaml (from example) if not present
# - Creates the Hermes Kanban board
# - Creates the 6 task-link DAG (one task per stage)
# - Sets task assignees to the stage profiles
# - Prints a summary of what was created

set -euo pipefail

SPARC_PKG_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$SPARC_PKG_ROOT/lib/stages.sh"
source "$SPARC_PKG_ROOT/lib/kanban.sh"
# source lib/config.sh so we can read sparc.config.yaml (for the board: field)
source "$SPARC_PKG_ROOT/lib/config.sh"

GOAL="${1:-}"

echo "→ Initializing SPARC+Design pipeline in: $(pwd)"
echo ""

# 1. sparc.config.yaml
if [[ -f "./sparc.config.yaml" ]]; then
  echo "  ✓ sparc.config.yaml already exists (not overwriting)"
else
  cp "$SPARC_PKG_ROOT/sparc.config.yaml.example" ./sparc.config.yaml
  echo "  ✓ created sparc.config.yaml (edit it to change stage gating, adapter, etc.)"
fi

# Board name precedence:
#   1. $SPARC_BOARD env var (for tests and one-off overrides)
#   2. `board:` field in ./sparc.config.yaml (if set and non-empty)
#   3. Derived from directory name (legacy fallback)
# This makes the user-facing config field actually take effect, which
# it didn't before v0.4.x (it was silently overridden by the dir
# name — see https://github.com/jb-bz/sparqr/issues/... bug).
if [[ -n "${SPARC_BOARD:-}" ]]; then
  BOARD="$SPARC_BOARD"
elif board_in_config=$(sparc_config_get ./sparc.config.yaml board 2>/dev/null) && [[ -n "$board_in_config" ]]; then
  BOARD="$board_in_config"
else
  BOARD="sparc-$(basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g')"
fi
echo "  • board name: $BOARD"

# 2. Kanban board
sparc_kanban_board_init "$BOARD" --name "SPARC: $(basename "$(pwd)")" --icon "🎯"

# 3. 6-stage DAG
echo ""
echo "→ Creating 6-task DAG (one task per stage)…"

# Use parallel indexed arrays (works in bash 3.2+, the macOS default)
STAGE_KEYS=()
TASK_IDS=()
PREV_ID=""
FIRST_STAGE=$(sparc_stage_first)
for STAGE in $(sparc_stage_all_keys); do
  # bash 3.2 (macOS default) doesn't interpret \U in sed, so use
  # awk for first-character uppercase. (Same fix as lib/kanban.sh.)
  TITLE="[$(echo "$STAGE" | tr '[:lower:]' '[:upper:]' | awk '{print toupper(substr($0,1,1)) substr($0,2)}')]"
  if [[ -n "$GOAL" && "$STAGE" == "$FIRST_STAGE" ]]; then
    TITLE="$TITLE $GOAL"
  elif [[ "$STAGE" == "$FIRST_STAGE" ]]; then
    TITLE="$TITLE (set the goal in sparc.config.yaml or pass it to sparc init)"
  fi

  if [[ -n "$PREV_ID" ]]; then
    NEW_ID=$(sparc_kanban_create_task "$BOARD" "$STAGE" "$TITLE" "$PREV_ID")
  else
    NEW_ID=$(sparc_kanban_create_task "$BOARD" "$STAGE" "$TITLE")
  fi
  STAGE_KEYS+=("$STAGE")
  TASK_IDS+=("$NEW_ID")
  PROFILE=$(sparc_stage_get "$STAGE" profile)
  echo "  ✓ [$STAGE] task=$NEW_ID  profile=$PROFILE"
  PREV_ID="$NEW_ID"
done

# 4. Summary
echo ""
echo "════════════════════════════════════════════════════════════════════"
echo "  SPARC pipeline ready"
echo "════════════════════════════════════════════════════════════════════"
echo "  Board    : $BOARD"
echo "  Tasks    : 6 stages linked parent→child"
echo "  HITL     : ${SPARC_HITL_ADAPTER:-terminal} (change in sparc.config.yaml)"
echo "  Next     : sparc pipeline start     (begin the orchestrator daemon)"
echo "           : sparc pipeline run-once  (single iteration, debug)"
echo "           : sparc doctor             (validate setup)"
echo "════════════════════════════════════════════════════════════════════"

# ── v0.4.1 story 4e: post-commit hook (opt-in) ───────────────────────
# Ask the user whether to install the post-commit hook that nudges
# them to run `sparc retro` when a release tag is added.
if [[ -d .git ]]; then
  if [[ ! -f .git/hooks/post-commit ]] || grep -q "sparqr reminder" .git/hooks/post-commit 2>/dev/null; then
    printf "  Install sparqr post-commit hook for retro reminders? [y/N] "
    read -r install_hook
    if [[ "$install_hook" =~ ^[Yy]$ ]]; then
      cp "$SPARC_PKG_ROOT/templates/post-commit-hook.sh" .git/hooks/post-commit
      chmod +x .git/hooks/post-commit
      echo "  ✓ installed .git/hooks/post-commit (sparqr retro reminder)"
    fi
  fi
fi

# ── v0.4.1 story 4a: story-point ledger (per-repo) ─────────────────
# .sparc/stories.yaml is created on first `sparc story add`.
# Reminder so the user knows the methodology exists.
echo ""
echo "  Tip: track story points for this project with \`sparc story\`."
echo "       e.g.: sparc story add 'Build the dashboard' --points 8"
echo "             sparc story list"
